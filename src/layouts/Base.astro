---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
}

const {
  title,
  description,
  image,
  article = false,
  pubDate,
  updatedDate,
  author = 'Jean-Baptiste Landmann',
  tags = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image
  ? new URL(image, Astro.site).href
  : new URL('/blog/og-default.png', Astro.site).href;
const siteName = 'JB Landmann';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} — {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
    <meta name="author" content={author} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    {pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    {article && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'BlogPosting',
          headline: title,
          description: description,
          image: ogImage,
          datePublished: pubDate?.toISOString(),
          dateModified: updatedDate?.toISOString() ?? pubDate?.toISOString(),
          author: {
            '@type': 'Person',
            name: author,
            url: 'https://github.com/JbLandmann',
          },
          publisher: {
            '@type': 'Person',
            name: author,
          },
          mainEntityOfPage: {
            '@type': 'WebPage',
            '@id': canonicalURL.href,
          },
          keywords: tags.join(', '),
        })}
      />
    )}

    <!-- Feeds -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={new URL('/blog/rss.xml', Astro.site)}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-bg text-fg font-sans flex flex-col antialiased leading-relaxed">
    <!-- Header -->
    <header class="border-b border-border">
      <div class="mx-auto max-w-[680px] px-5 py-4 flex items-center justify-between">
        <a href="/blog/" class="text-fg-strong font-bold tracking-tight hover:text-accent transition-colors">
          {siteName}
        </a>
        <nav class="flex items-center gap-6">
          <a href="/blog/" class="text-sm text-fg-muted link-hover font-medium">Articles</a>
          <a href="/blog/rss.xml" class="text-sm text-fg-muted link-hover font-medium">RSS</a>
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main class="flex-1 py-12 sm:py-16">
      <div class="mx-auto max-w-[680px] px-5">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto border-t border-border">
      <div class="mx-auto max-w-[680px] px-5 py-8 text-center text-xs text-fg-muted">
        <p>© {new Date().getFullYear()} {siteName}. Tous droits réservés.</p>
      </div>
    </footer>
  </body>
</html>
