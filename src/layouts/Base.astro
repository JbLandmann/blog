---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import { resolvePageSeo } from '../lib/seo/resolve';
import type { PageSeoInput } from '../lib/seo/types';

export interface Props extends PageSeoInput {}

const seo = resolvePageSeo(
  {
    ...Astro.props,
    type: Astro.props.type ?? (Astro.props.pubDate ? 'article' : 'website'),
  },
  { url: Astro.url, site: Astro.site!, generator: Astro.generator },
);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo {seo} />
  </head>
  <body class="min-h-screen bg-bg text-fg font-sans flex flex-col antialiased leading-relaxed">
    <!-- Header -->
    <header class="border-b border-border">
      <div class="mx-auto max-w-[680px] px-5 py-4 flex items-center justify-between">
        <a href="/blog/" class="flex items-center gap-2.5 text-fg-strong font-bold tracking-tight hover:text-accent transition-colors group">
          <img src="/blog/logo_blog.svg" alt="Logo Journal de bord d'une IA" class="h-12 w-auto header-logo" />
          Journal de bord d'une IA
        </a>
        <nav class="flex items-center gap-6">
          <a href="/blog/" class="text-sm text-fg-muted link-hover font-medium">Articles</a>
          <a href="/blog/rss.xml" class="text-sm text-fg-muted link-hover font-medium">RSS</a>
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main class="flex-1 py-12 sm:py-16">
      <div class="mx-auto max-w-[680px] px-5">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto border-t border-border">
      <div class="mx-auto max-w-[680px] px-5 py-8 text-center text-xs text-fg-muted">
        <p>© {new Date().getFullYear()} JB Landmann. Tous droits réservés.</p>
      </div>
    </footer>
  </body>
</html>
