---
import type { ResolvedSeo } from '../lib/seo/types';

interface Props {
  seo: ResolvedSeo;
}

const { seo } = Astro.props;
---

<title>{seo.fullTitle}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonicalUrl} />
{seo.keywords && <meta name="keywords" content={seo.keywords} />}
<meta name="author" content={seo.author} />
{seo.generator && <meta name="generator" content={seo.generator} />}

<!-- Open Graph -->
<meta property="og:type" content={seo.og.type} />
<meta property="og:title" content={seo.og.title} />
<meta property="og:description" content={seo.og.description} />
<meta property="og:url" content={seo.og.url} />
<meta property="og:site_name" content={seo.og.siteName} />
<meta property="og:image" content={seo.og.image} />
<meta property="og:locale" content={seo.og.locale} />
{seo.og.publishedTime && (
  <meta property="article:published_time" content={seo.og.publishedTime} />
)}
{seo.og.modifiedTime && (
  <meta property="article:modified_time" content={seo.og.modifiedTime} />
)}
{seo.og.tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter Card -->
<meta name="twitter:card" content={seo.twitter.card} />
<meta name="twitter:title" content={seo.twitter.title} />
<meta name="twitter:description" content={seo.twitter.description} />
<meta name="twitter:image" content={seo.twitter.image} />

<!-- JSON-LD Structured Data -->
{seo.jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
)}

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href={seo.favicons.svg} />
<link rel="icon" type="image/png" href={seo.favicons.png} />
<link rel="apple-touch-icon" href={seo.favicons.appleTouchIcon} />

<!-- Feeds -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={seo.og.siteName}
  href={seo.rssUrl}
/>

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href={seo.fontsUrl} rel="stylesheet" />
